# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# VS Code - launch configs you may want in version control, commented out by default
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# ─── Android ──────────────────────────────────────────────────────────────────
# Android Studio build artifacts
/android/app/debug
/android/app/profile
/android/app/release

# Android local config (contains machine-specific SDK path)
android/local.properties

# Gradle wrapper
android/.gradle/
android/gradle/wrapper/gradle-wrapper.jar

# Generated key properties (keep your keystore out of git!)
android/key.properties
*.jks
*.keystore

# ─── iOS ──────────────────────────────────────────────────────────────────────
# Xcode build artifacts
**/ios/Flutter/.last_build_id
**/ios/Pods/
**/ios/.symlinks/
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Runner/GeneratedPluginRegistrant.*

# CocoaPods lockfile can be committed, but the resolved Pods dir should not
ios/Podfile.lock

# Xcode user data
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/*.xcodeproj/project.xcworkspace/

# ─── Web ──────────────────────────────────────────────────────────────────────
# Dart-generated web files
lib/generated_plugin_registrant.dart
web/flutter_service_worker.js
web/flutter.js
web/main.dart.js
web/main.dart.js.map

# Service worker cache (generated at build time)
/web/.dart_tool/
